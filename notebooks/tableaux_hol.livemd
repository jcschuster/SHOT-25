x_abstr = mk_abstr_term(equality, x)
f_abstr = mk_abstr_term(mk_appl_term(pi_io_term, x_abstr), f)

formula = mk_appl_term(pi_ii_o_term, f_abstr)
PrettyPrint.pp_term(formula)
